{
  "schemaVersion": 1,
  "id": "hermitpurple",
  "version": "${version}",
  "name": "JCraft Hermit Purple Addon",
  "description": "Adds the stand of Joseph Joestar, Hermit Purple, into JCraft!",
  "authors": [
    "Arsik"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "MIT",
  "icon": "assets/hermitpurple/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.arsik.hermitpurple.fabric.HermitPurpleFabric"
    ],
    "client": [
      "net.arsik.hermitpurple.fabric.client.HermitPurpleFabricClient"
    ],
    "fabric-datagen": [
      "net.arsik.hermitpurple.fabric.datagen.HermitPurpleDataGen"
    ]
  },
  "mixins": [
    "hermitpurple.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.14",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "architectury": ">=9.2.14",
    "jcraft": ">=0.18.0"
  }
}
